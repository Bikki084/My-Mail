# Local setup: run `npm run setup:env` to create .env.local from this file (never commit .env.local).
# Supabase (https://supabase.com/dashboard)
# NEXT_PUBLIC_SUPABASE_URL must be the project URL only, e.g. https://xxxx.supabase.co
# (do NOT append /rest/v1 — that breaks Auth and shows "Invalid path specified in request URL" on login).
# Leave unset (or invalid placeholder) during UI-only dev: in `next dev`, /client works
# without login (preview banner + static UI). Set real values to enable auth + data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: add **only on your machine** to run `npm run create-admin` once, then remove.
# Settings → API → service_role (never ship to the browser or commit to git).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for `npm run db:migrate` and auto-migrate on server start (recommended).
# Get a token at https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
#
# Alternative: direct Postgres URL (Dashboard → Settings → Database → URI)
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
#
# If neither is set, paste supabase/essential-for-send.sql in Supabase SQL Editor once.
#
# Optional: required only to run `npm run db:migrate` (applies supabase/migrations/*.sql).
# Pick ONE of these two paths.
#
# Path A (recommended — no DB password needed):
#   1. Visit https://supabase.com/dashboard/account/tokens
#   2. Click "Generate new token", copy the value (shown once).
#   3. Uncomment and paste below.
# SUPABASE_ACCESS_TOKEN=sbp_...
#     Then: npm run db:migrate
#     If the first migration fails (DB already bootstrapped), run:
#     npm run db:migrate:wallet
#
# Path B (direct Postgres connection):
#   1. Dashboard → Settings → Database → Connection string → URI tab.
#   2. Copy the string, replace [YOUR-PASSWORD] with the DB password.
# SUPABASE_DB_URL=postgresql://postgres:YOURPASSWORD@db.xxx.supabase.co:5432/postgres
# Optional bootstrap (defaults: mymail87455@gmail.com + min 6 char password)
# BOOTSTRAP_ADMIN_EMAIL=mymail87455@gmail.com
# BOOTSTRAP_ADMIN_PASSWORD=admin123
#
# Admin password reset emails (Nodemailer). Required to actually receive reset mail at the admin address.
# Without these variables the API still returns success (anti-enumeration); in `next dev` a one-time
# reset link may appear on-screen if sending fails.
#
# If Gmail rejects ADMIN_RESET_SMTP_PASS (535), the server falls back to Supabase Auth email. Add this
# exact URL to Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/update-password
# (and your production URL + /auth/update-password when you deploy.)
# Link base: set NEXT_PUBLIC_APP_URL in production (no trailing slash), e.g. https://app.example.com
# NEXT_PUBLIC_APP_URL=https://app.example.com
# For Gmail you can omit host/port (app uses Nodemailer service preset). For other SMTP, set host + port.
# ADMIN_RESET_SMTP_HOST=smtp.gmail.com
# ADMIN_RESET_SMTP_PORT=587
# ADMIN_RESET_SMTP_SECURE=0
# Set to 1 if connection to Google SMTP fails on your network (forces IPv4).
# ADMIN_RESET_SMTP_IPV4=1
# Set to 1 only while debugging Gmail SMTP (verbose Nodemailer logs in the terminal).
# ADMIN_RESET_SMTP_DEBUG=1
# ADMIN_RESET_SMTP_USER=mymail87455@gmail.com
# ADMIN_RESET_SMTP_PASS=your-app-password
# ADMIN_RESET_MAIL_FROM=MyMail <mymail87455@gmail.com>

# --- Gmail API (OAuth test scripts — not wired into campaign UI yet) ------------
# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client (Web application)
# Enable Gmail API. Add redirect URI: http://localhost:3456/oauth2callback
# GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3456/oauth2callback
# Then: npm run gmail:auth
#       npm run gmail:send-test -- --csv recipients.csv --limit 40
# Google Auth Platform → Data Access → add scope: .../auth/gmail.send (required)

# BullMQ worker (optional for local). If REDIS_URL is unset, the app still sends mail
# synchronously in the API (small campaigns; increase limit in `send` route if needed).
REDIS_URL=redis://127.0.0.1:6379
# Production (VPS): run Redis + BOTH PM2 apps — `pm2 start ecosystem.config.cjs`
# (mymail-web + mymail-worker). If only the web app runs, small sends (≤200 recipients)
# still deliver in-process; large sends return an error until the worker is up.
# When REDIS_URL is set, `npm run dev` also starts the email worker (no second terminal).
# Next.js only: npm run dev:next. Worker only: npm run worker.
# FORCE_EMAIL_QUEUE=1 — never fall back to in-process when the worker is missing (503 instead).
#
# HTML → PDF/image attachments (Puppeteer). On Ubuntu VPS install system Chrome libs:
#   sudo bash scripts/install-chromium-deps.sh
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Set to 1 in .env.local only to queue sends when email credits are 0 (local testing).
# Remove in production; clients should have credits assigned in admin.
# ALLOW_SEND_WITHOUT_EMAIL_CREDITS=1

# --- Deliverability (helps Yahoo/Outlook/Gmail inbox placement) ---------------
#
# READ FIRST — why mail goes to Outlook Junk and what actually fixes it:
#
#   The two header improvements below help, but Outlook's SmartScreen filter
#   weights *sender authentication* and *sender reputation* far more than
#   message contents. If your mail is landing in Junk, in priority order:
#
#   1) Don't send from a free-mail address (gmail.com, yahoo.com, outlook.com)
#      with bulk-style content. Microsoft heavily penalises this. Use a
#      domain you own (e.g. mail.your-co.com) and a transactional SMTP relay
#      (Brevo, SendGrid, Mailgun, Postmark, Amazon SES, Resend). Free tiers
#      ship 100–300/day for free.
#   2) Publish SPF, DKIM, and DMARC TXT records on the From domain. Most ESPs
#      (Brevo, SendGrid, etc.) walk you through this in their UI. Verify with
#      https://www.mail-tester.com (aim for 9+/10). DKIM-aligned signature
#      with the From domain is the #1 thing Outlook looks for.
#   3) Sign up for Microsoft SNDS + JMRP (free), at
#      https://sendersupport.olc.protection.outlook.com/snds/  and
#      https://sendersupport.olc.protection.outlook.com/pm/  — gives you
#      visibility into Outlook's view of your sender reputation.
#   4) Warm up: start with low daily volume (50–100/day) to engaged contacts,
#      grow gradually. Outlook learns sender reputation per IP+domain and is
#      hostile to brand-new senders blasting thousands.
#   5) Ask the recipient to right-click the message → "Mark as not junk" and
#      add your From address to "Safe Senders". One-time fix that also tells
#      Outlook to trust your domain going forward.
#
# Public origin of the app (no trailing slash). When set, every send adds an
# HTTPS one-click List-Unsubscribe URL pointing at /api/unsubscribe and the
# `List-Unsubscribe-Post: List-Unsubscribe=One-Click` header (RFC 8058).
# Without it, only the mailto: form is sent — still helpful, but Yahoo
# requires the HTTPS form once a domain ships > 5K msgs/day, and Outlook
# does fetch the URL to validate it returns 2xx (we now serve it under
# /api/unsubscribe — apply the unsubscribes migration so suppressions persist).
# MAILER_PUBLIC_URL=https://send.example.com
#
# Mailbox that receives mailto: unsubscribe requests. Defaults to the From
# address (the SMTP username). Use a real, monitored inbox if you can.
# MAILER_UNSUBSCRIBE_MAILBOX=unsubscribe@example.com
#
# Optional postal address line for the auto-injected footer (CAN-SPAM § 5(a)(5)).
# Required by US law for commercial email; harmless and useful elsewhere too.
# MAILER_POSTAL_ADDRESS=Acme Inc, 123 Main St, Springfield, IL 62701, USA
#
# Optional in-process DKIM signing. Most relays (Gmail SMTP, SendGrid, SES,
# Brevo, Mailgun) already DKIM-sign at the relay — leave these unset in that
# case. Only fill them if you run your own SMTP (e.g. Postfix without
# opendkim) or want a second signature.
#
#   1. Publish a TXT record at <selector>._domainkey.<domain> containing the
#      public key. See https://easydmarc.com/tools/dkim-record-generator
#   2. Paste the *private* key below. Multi-line keys can be passed as a
#      single line by replacing newlines with literal `\n`.
# DKIM_DOMAIN=example.com
# DKIM_KEY_SELECTOR=mail
# DKIM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# AES-256-GCM key used to encrypt SMTP passwords stored in smtp_servers.password_enc.
# MUST decode to exactly 32 bytes. Either base64 (44 chars) or hex (64 chars) is accepted.
# Generate one with any of:
#   openssl rand -base64 32
#   PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#   Node:      node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotate by re-saving each SMTP row after swapping the key (decrypt with the old key,
# re-encrypt with the new one). Do NOT commit a real key to git.
SMTP_ENCRYPTION_KEY=replace-with-base64-or-hex-32-byte-key

# --- Campaign IP rotation (after every N successful sends) -------------------
#
# Default: after `rotation_threshold` sends (usually 1000), the worker calls
# `rotateOutboundIp` and continues without pausing. Set to 1 to restore the
# old behaviour (pause until the user manually refreshes IP and resumes).
# CAMPAIGN_MANUAL_IP_ROTATION_PAUSE=1
#
# --- Bulk send throughput (parallel SMTP + pooled connections) ---------------
# Parallel in-flight sends per SMTP account (default 10). Raise with multiple
# distinct SMTP logins; Gmail may throttle above ~5–10 per mailbox.
# SMTP_WORKER_CONCURRENCY=10
# SMTP_MAX_CONNECTIONS=10
# SMTP_POOL=1
# SMTP_CONNECTION_TIMEOUT_MS=8000
# HTML_RENDER_CONCURRENCY=4
# HTML_RENDER_WAIT_UNTIL=domcontentloaded
# MAX_SYNC_RECIPIENTS=5000
#
# Optional: HTTP URL that returns the new egress IPv4 after each burst (plain
# text or JSON with an "ip" field). Use this to integrate Bright Data,
# Oxylabs, SmartProxy, or your own VPS script that changes exit IP / rotates proxy.
# If unset, a synthetic IPv4 is stored for audit/UI only (SMTP still uses your
# server's route unless you proxy at the network layer).
# OUTBOUND_IP_ROTATION_URL=https://your-rotation-service.example/next-ip
# OUTBOUND_IP_ROTATION_TOKEN=optional-bearer-token
# OUTBOUND_IP_ROTATION_METHOD=POST
# OUTBOUND_IP_ROTATION_POST_BODY={}
# OUTBOUND_IP_ROTATION_TIMEOUT_MS=30000
#
# --- Real egress IP rotation (pick ONE mode) ----------------------------------
#
# OUTBOUND_IP_EGRESS_MODE controls whether rotation changes real network traffic:
#
#   lightsail  — REAL: AWS attaches your static IP on this VPS before sends.
#                Pool = AWS_LIGHTSAIL_STATIC_IP_NAMES + OUTBOUND_IP_POOL (no fake IPs).
#                Max ~5 IPs per Lightsail instance. Use with Postfix on 127.0.0.1:25
#                for direct mail, or SMTP relays still see your VPS/proxy path.
#
#   proxy      — REAL: each SMTP worker uses a SOCKS5 proxy (parallel egress).
#                Set OUTBOUND_IP_PROXY_POOL (10 URLs for 500-credit / 10-server plan).
#                Set OUTBOUND_IP_POOL to the matching exit IPs for the UI (same order).
#
#   logical    — UI/audit only (synthetic IPs). Not real egress rotation.
#
# Default when unset: lightsail if AWS pool configured, else proxy if proxy pool set.
# OUTBOUND_IP_EGRESS_MODE=lightsail
#
# OUTBOUND_IP_EGRESS_MODE=proxy
#
# Option A — auto bind each AWS static IP (NOT supported on AWS Lightsail — use logical mode instead):
# OUTBOUND_IP_PROXY_AUTO_BIND=1
#
# Option B — explicit bind routes (NOT on Lightsail — EINVAL; EC2 with secondary ENI only):
# OUTBOUND_IP_PROXY_POOL=bind://13.203.176.51,bind://15.206.86.111,...
#
# Option C — external SOCKS5 proxies (real host/credentials only — not user:pass@real-proxy1):
# OUTBOUND_IP_PROXY_POOL=socks5://user:pass@proxy1.example:1080
#
# If using AUTO_BIND, leave OUTBOUND_IP_PROXY_POOL unset (example URLs break routing).
#
# Display / tracking IPs — optional; use your real Lightsail static IPs (never 1.2.3.4 placeholders).
# OUTBOUND_IP_POOL=13.203.176.51,15.206.86.111,13.203.129.91,13.235.93.38,13.232.7.155
#
# --- Legacy virtual pool (only when OUTBOUND_IP_EGRESS_MODE=logical) ------------
# OUTBOUND_IP_VIRTUAL_POOL=1
# OUTBOUND_IP_VIRTUAL_POOL_MIN=50
# OUTBOUND_IP_SKIP_LIGHTSAIL_ATTACH=1
#
# --- AWS Lightsail IP pool (recommended on your VPS) -------------------------
# Requires 2+ static IPs (e.g. 5 total: 1 website primary + 4 send IPs).
# Default: pool rotation — primary stays attached for the website; Refresh cycles
# through send IPs only; campaigns attach the active send IP for SMTP egress and
# restore the primary when sending finishes.
# AWS_LIGHTSAIL_REGION=ap-south-1
# AWS_LIGHTSAIL_INSTANCE_NAME=Ubuntu-1
# AWS_LIGHTSAIL_STATIC_IP_NAMES=StaticIp-1,StaticIp-2,StaticIp-3,StaticIp-4,StaticIp-5
# AWS_LIGHTSAIL_PRIMARY_STATIC_IP_NAME=StaticIp-1
# Optional: map names to IPv4 to avoid pool lookup API calls (attach/detach still use AWS):
# AWS_LIGHTSAIL_STATIC_IP_MAP=StaticIp-1:13.203.176.51,StaticIp-2:13.203.129.91,StaticIp-3:...
# AWS_LIGHTSAIL_API_MIN_INTERVAL_MS=800
# AWS_LIGHTSAIL_API_MAX_RETRIES=6
# AWS_LIGHTSAIL_SWAP_ATTACH_ON_ROTATE=1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
